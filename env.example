# Copy this file to .env locally, or set these as Environment Variables in
# your hosting dashboard. Never commit your real .env file or token anywhere.

# From the API Setup screen in your Meta App dashboard:
WHATSAPP_TOKEN=
PHONE_NUMBER_ID=

# Make this up yourself - any string. You'll paste the SAME value into the
# Meta dashboard's webhook "Verify token" field.
VERIFY_TOKEN=

# Usually fine to leave as-is
PORT=3000
